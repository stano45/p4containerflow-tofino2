flowchart TB
    CTRL[local controller]

    CTRL -- SSH --> SW
    CTRL -- SSH --> L
    CTRL -- SSH --> V

    L[lakewood] -- 25G --- SW[Tofino Switch]
    SW -- 25G --- V[loveland]
    L -- 25G DAC --- V

    style L fill:#c8e6c9,stroke:#388e3c
    style V fill:#c8e6c9,stroke:#388e3c
