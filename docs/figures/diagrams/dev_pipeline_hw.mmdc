flowchart TB
    SB["rebuild SDE with drivers + BSP"]
    DP["deploy P4 binary"]
    KM["load kernel modules"]
    SW["bf_switchd on hardware"]
    TE["pytest + manual verification"]
    EX["run experiments on testbed"]

    SB --> DP
    DP --> KM
    KM --> SW
    SW --> TE
    TE -- "iterate" --> SB
    TE --> EX

